# ═══════════════════════════════════════════════════════════════════
# StrokeSync Environment Variables
# HIPAA-Compliant Configuration
# ═══════════════════════════════════════════════════════════════════

# ─── Database ───────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:password@localhost:5432/strokesync?schema=public"

# ─── Authentication ─────────────────────────────────────────
JWT_SECRET="your-jwt-secret-key-min-32-chars-long"
JWT_REFRESH_SECRET="your-refresh-secret-key-min-32-chars"
JWT_ACCESS_TOKEN_EXPIRY="15m"
JWT_REFRESH_TOKEN_EXPIRY="7d"

# ─── Redis (Session + Cache) ───────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── HIPAA Encryption (AES-256 via pgcrypto) ───────────────
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY="your-256-bit-encryption-key-here!!"
ENCRYPTION_IV_LENGTH=16

# ─── Server ─────────────────────────────────────────────────
BACKEND_PORT=4000
BACKEND_URL="http://localhost:4000"
WEB_PORT=3000
WEB_URL="http://localhost:3000"

# ─── CORS ───────────────────────────────────────────────────
CORS_ORIGINS="http://localhost:3000,http://localhost:8081"

# ─── Node Environment ──────────────────────────────────────
NODE_ENV="development"

# ─── Audit & Compliance ────────────────────────────────────
AUDIT_LOG_RETENTION_DAYS=2555
PHI_ACCESS_LOG_LEVEL="verbose"

# ─── Session Timeout (HIPAA §164.312(a)(2)(iii)) ──────────
SESSION_TIMEOUT_MINUTES=15
AUTO_LOGOUT_ENABLED=true

# ─── Rate Limiting ─────────────────────────────────────────
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100
